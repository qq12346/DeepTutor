# DeepTutor CloudBase 双服务示例环境变量
# 用途：腾讯云 CloudBase 同一环境下分别部署 frontend / backend 两个云托管服务
#
# 建议：
# 1) backend 服务单独暴露为一个 HTTP 服务，例如路径 `/api`
# 2) frontend 服务单独暴露为一个 HTTP 服务，例如路径 `/`
# 3) frontend 的 NEXT_PUBLIC_API_BASE_EXTERNAL 指向后端的公网基础地址
#    - 如果通过 HTTP 访问服务把 backend 绑定到同域名的 `/api`
#      那么这里直接填 https://你的域名
#    - 如果 backend 使用独立默认域名
#      那么这里填 https://backend-xxxxx.run.tcloudbase.com

# =========================
# Backend 服务（云托管）
# =========================
# backend 服务监听 CloudBase 注入的 PORT，无需再手工固定 8001
LLM_BINDING=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-xxx
LLM_HOST=https://api.openai.com/v1
LLM_API_VERSION=

EMBEDDING_BINDING=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_API_KEY=sk-xxx
EMBEDDING_HOST=https://api.openai.com/v1/embeddings
EMBEDDING_DIMENSION=
EMBEDDING_API_VERSION=
EMBEDDING_SEND_DIMENSIONS=

SILICONFLOW_API_KEY=
DASHSCOPE_API_KEY=
COHERE_API_KEY=
JINA_API_KEY=

SEARCH_PROVIDER=
SEARCH_API_KEY=
SEARCH_BASE_URL=
DISABLE_SSL_VERIFY=false
CHAT_ATTACHMENT_DIR=

# =========================
# Frontend 服务（云托管）
# =========================
# 推荐填后端的公网根地址；前端代码会自行拼接 /api/... 和 /api/v1/ws
NEXT_PUBLIC_API_BASE_EXTERNAL=
# 如有特殊需要，也可直接写完整 API 基址
NEXT_PUBLIC_API_BASE=
